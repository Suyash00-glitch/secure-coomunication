CREATE TABLE IF NOT EXISTS tickets (

ticket_id INT AUTO_INCREMENT PRIMARY KEY,

ticket_number VARCHAR(50)
UNIQUE,

title VARCHAR(250)
NOT NULL,

description TEXT,

created_by INT
NOT NULL,

assigned_department INT
NOT NULL,

assigned_to INT,

status_id INT
NOT NULL
DEFAULT 1,

acknowledgement_at TIMESTAMP,

created_at TIMESTAMP
DEFAULT CURRENT_TIMESTAMP,

updated_at TIMESTAMP
DEFAULT CURRENT_TIMESTAMP
ON UPDATE CURRENT_TIMESTAMP,

closed_at TIMESTAMP,

FOREIGN KEY
(created_by)

REFERENCES
users(user_id),

FOREIGN KEY
(assigned_department)

REFERENCES
departments(department_id),

FOREIGN KEY
(assigned_to)

REFERENCES
users(user_id),

FOREIGN KEY
(status_id)

REFERENCES
status_master(status_id)

);



